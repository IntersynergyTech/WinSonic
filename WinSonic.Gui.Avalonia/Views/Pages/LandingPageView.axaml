<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:WinSonic.Gui.Avalonia.ViewModels.Pages"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WinSonic.Gui.Avalonia.Views.Pages.LandingPageView"
             x:DataType="pages:LandingPageViewModel">
    <Design.DataContext>
        <pages:LandingPageViewModel />
    </Design.DataContext>
    <StackPanel>
        <TextBlock Text="{Binding Title}" />
        <Button Content="{Binding SettingsButtonText}"></Button>
    </StackPanel>
</UserControl>
